<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="?attr/colorSurface">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/options"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOutline"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menu_edit"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/edit_labour"
            android:gravity="start|center_vertical"
            android:textColor="?attr/colorOnSurface"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="?attr/colorOnSurfaceVariant"
            app:iconSize="22dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textAllCaps="false"
            android:textSize="15sp"/>

        <LinearLayout
            android:id="@+id/menu_toggle_company"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@string/company_info_icon"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/show_company_info"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_company"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_toggle_signature"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_signature"
                app:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@string/signature_icon"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/show_signature_stamp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_signature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:layout_marginVertical="12dp"
            android:layout_marginHorizontal="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menu_delete"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/delete_labour"
            android:gravity="start|center_vertical"
            android:textColor="?attr/colorError"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconTint="?attr/colorError"
            app:iconSize="22dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textAllCaps="false"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/menu_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:text="@string/close"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textSize="15sp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
