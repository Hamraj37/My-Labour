<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:background="?attr/colorSurface">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Labour Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginStart="8dp" />

            <ImageButton
                android:id="@+id/btn_more"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_more"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnSurface"
                android:contentDescription="More options" />

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/content_to_export"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/colorSurface">

                <!-- Horizontal Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/iv_detail_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_person"
                            android:contentDescription="Avatar" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_detail_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="John Doe"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_detail_section"
                    android:padding="16dp">

                    <!-- Horizontal Phone Field -->
                    <LinearLayout
                        android:id="@+id/layout_copy_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="4dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Phone"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOutline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tv_detail_number"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="+91 9876543210"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="viewEnd"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_total"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginBottom="16dp"/>

                    <!-- Horizontal Email Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOutline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tv_detail_email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="john@example.com"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="viewEnd"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_total"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginBottom="16dp"/>

                    <!-- Horizontal Address Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Address"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOutline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tv_detail_address"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="123 Main St, City"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="viewEnd"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Horizontal Previous Due Field -->
                    <LinearLayout
                        android:id="@+id/layout_previous_due"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Prev. Due"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOutline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tv_previous_due"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₹0"
                            android:textSize="16sp"
                            android:textColor="#C62828"
                            android:textAlignment="viewEnd"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_prev_due"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginBottom="16dp"
                        android:visibility="visible"/>

                    <!-- Horizontal Total Amount Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Total Amount"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOutline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tv_total_amount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₹0"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="viewEnd"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_total"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginBottom="16dp"/>

                    <!-- Horizontal Paid Amount Field -->
                    <LinearLayout
                        android:id="@+id/layout_paid_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Paid"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOutline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tv_paid_amount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₹0"
                            android:textSize="16sp"
                            android:textColor="#2E7D32"
                            android:textAlignment="viewEnd"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_paid"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone"/>

                    <!-- Horizontal Due Field -->
                    <LinearLayout
                        android:id="@+id/layout_due_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Due"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOutline"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tv_due_amount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₹0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"
                            android:textAlignment="viewEnd"/>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:baselineAligned="false">

                    <!-- Full Day Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E8F5E9">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_full_day_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Full Day"
                                android:textSize="12sp"
                                android:textColor="#2E7D32"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Half Day Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFF3E0">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_half_day_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#EF6C00"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Half Day"
                                android:textSize="12sp"
                                android:textColor="#EF6C00"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Absent Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFEBEE">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_absent_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#C62828"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Absent"
                                android:textSize="12sp"
                                android:textColor="#C62828"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Work Calendar"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <ImageButton
                                android:id="@+id/btn_prev_month"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_back"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Previous Month"
                                app:tint="?attr/colorOnSurface"/>

                            <TextView
                                android:id="@+id/tv_month_year"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Current Month"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textAlignment="center"
                                android:textColor="?attr/colorOnSurface"/>

                            <ImageButton
                                android:id="@+id/btn_next_month"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_back"
                                android:rotation="180"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Next Month"
                                app:tint="?attr/colorOnSurface"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_edit_wage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp"
                            android:padding="8dp"
                            android:background="@drawable/bg_detail_section"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Daily Wage for this month"
                                android:textSize="13sp"
                                android:textColor="?attr/colorOutline"/>

                            <TextView
                                android:id="@+id/tv_detail_wage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="16sp"
                                android:textColor="?attr/colorPrimary"
                                android:textStyle="bold"
                                android:padding="4dp"/>
                        </LinearLayout>

                        <!-- Weekdays Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textAlignment="center" android:textSize="12sp" android:textColor="?attr/colorOutline"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="M" android:textAlignment="center" android:textSize="12sp" android:textColor="?attr/colorOutline"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textAlignment="center" android:textSize="12sp" android:textColor="?attr/colorOutline"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="W" android:textAlignment="center" android:textSize="12sp" android:textColor="?attr/colorOutline"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T" android:textAlignment="center" android:textSize="12sp" android:textColor="?attr/colorOutline"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="F" android:textAlignment="center" android:textSize="12sp" android:textColor="?attr/colorOutline"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="S" android:textAlignment="center" android:textSize="12sp" android:textColor="?attr/colorOutline"/>
                        </LinearLayout>

                        <GridView
                            android:id="@+id/calendar_grid"
                            android:layout_width="match_parent"
                            android:layout_height="280dp"
                            android:numColumns="7"
                            android:verticalSpacing="4dp"
                            android:horizontalSpacing="4dp"
                            android:stretchMode="columnWidth"
                            android:scrollbars="none"/>
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="12dp">

                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#2E7D32" android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full Day" android:textSize="10sp" android:layout_marginEnd="16dp"/>

                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#EF6C00" android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Half Day" android:textSize="10sp" android:layout_marginEnd="16dp"/>

                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#C62828" android:layout_marginEnd="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Absent" android:textSize="10sp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_behavior="@string/hide_bottom_view_on_scroll_behavior">

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_set_paid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Set Paid"
            android:textColor="?attr/colorOnPrimary"
            app:backgroundTint="?attr/colorPrimary"
            app:icon="@android:drawable/ic_menu_save"
            app:iconTint="?attr/colorOnPrimary"
            style="@style/Widget.Material3.ExtendedFloatingActionButton.Primary"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_share"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Share as PDF"
            app:srcCompat="@drawable/ic_share"
            app:backgroundTint="?attr/colorPrimaryContainer"
            app:tint="?attr/colorOnPrimaryContainer"
            app:elevation="0dp"
            style="@style/Widget.Material3.FloatingActionButton.Primary"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
